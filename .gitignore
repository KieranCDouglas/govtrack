# Build outputs that don't match deployed assets
# The deployed bundle is index-C3q1xJnh.js / ui-vendor-b_2lAFDP.js
# Any rebuild generates new hashes — ignore those to prevent accidental overwrites
assets/index-*.js
assets/index-*.css
assets/ui-vendor-*.js
assets/query-vendor-*.js
